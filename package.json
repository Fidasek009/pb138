{
	"name": "pb138",
	"private": true,
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"prepare": "husky",
		"db:start": "docker compose up -d db --wait",
		"db:logs": "docker compose logs --follow db",
		"dev": "turbo run dev db:logs",
		"dev:web": "turbo dev --filter=web",
		"dev:api": "turbo dev --filter=api",
		"build": "turbo build",
		"lint": "turbo lint",
		"check": "biome check .",
		"type-check": "turbo type-check",
		"test": "turbo test",
		"format": "biome format --write .",
		"fix": "biome check --write --unsafe ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.0",
		"turbo": "^2.6.3"
	},
	"lint-staged": {
		"**/*.{ts,tsx,js,jsx,json,css}": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"dependencies": {
		"zod": "^4.3.6"
	}
}
