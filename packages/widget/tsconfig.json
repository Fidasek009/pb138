{
	"compilerOptions": {
		"lib": ["ESNext", "DOM"],
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationDir": "./dist",
		"emitDeclarationOnly": true,
		"noEmit": false
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
